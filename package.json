{
  "name": "@adam-rocska/font-anatomy",
  "version": "1.1.4",
  "description": "Extract font anatomy metrics from TTF, OTF, and WOFF2 in TypeScript and from the command line.",
  "keywords": [
    "font",
    "font-anatomy",
    "font-metrics",
    "vertical-metrics",
    "x-height",
    "cap-height",
    "ascender",
    "descender",
    "opentype",
    "ttf",
    "otf",
    "woff2",
    "typography",
    "typeface",
    "typescript",
    "font-cli"
  ],
  "author": {
    "name": "Ádám László Rocska",
    "url": "https://adam-rocska.github.io"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adam-rocska/font-anatomy-typescript.git"
  },
  "homepage": "https://github.com/adam-rocska/font-anatomy-typescript#readme",
  "bugs": {
    "url": "https://github.com/adam-rocska/font-anatomy-typescript/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/adam-rocska"
    }
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "bunchee && chmod +x dist/bin/font-anatomy.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"bin/**/*.mjs\" \"eslint.config.mjs\" \"vitest.config.mts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && npm_config_cache=.npm-cache pnpm attw --pack"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^24.12.2",
    "@types/opentype.js": "^1.3.9",
    "@types/wawoff2": "^1.0.2",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.5",
    "bunchee": "^6.10.0",
    "eslint": "^10.2.1",
    "pnpm": "^10.33.0",
    "rimraf": "^6.1.3",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yargs": "^18.0.0"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/es/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.mts",
        "default": "./dist/es/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "bin": {
    "font-anatomy": "dist/bin/font-anatomy.js"
  },
  "dependencies": {
    "@adam-rocska/markdown-table": "^1.0.2",
    "opentype.js": "^1.3.4",
    "wawoff2": "^2.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0"
}
